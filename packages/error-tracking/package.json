{
  "name": "@joolie-boolie/error-tracking",
  "version": "0.1.0",
  "private": true,
  "description": "Error tracking abstraction for Joolie Boolie with support for multiple backends",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./client": "./src/client.ts",
    "./server": "./src/server.ts",
    "./react": "./src/react.tsx",
    "./types": "./src/types.ts",
    "./server-logger": "./src/server-logger.ts",
    "./faro": "./src/faro.ts",
    "./sentry": "./src/sentry.ts",
    "./monitoring-tunnel": "./src/monitoring-tunnel.ts",
    "./components": "./src/components/FaroInit.tsx"
  },
  "scripts": {
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@grafana/faro-react": "^2.2.4",
    "@grafana/faro-web-sdk": "^2.2.4"
  },
  "peerDependencies": {
    "@sentry/nextjs": ">=8.0.0",
    "next": ">=14.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "peerDependenciesMeta": {
    "@sentry/nextjs": {
      "optional": true
    },
    "next": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "devDependencies": {
    "@joolie-boolie/testing": "workspace:*",
    "@sentry/nextjs": "^10.39.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.1.2",
    "@vitest/coverage-v8": "^4.0.17",
    "jsdom": "^27.4.0",
    "typescript": "^5",
    "vitest": "^4.0.17"
  },
  "keywords": [
    "error-tracking",
    "error-boundary",
    "logging",
    "joolie-boolie"
  ]
}
