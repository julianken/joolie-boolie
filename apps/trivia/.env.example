# =============================================================================
# Trivia Night - Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the values

# -----------------------------------------------------------------------------
# Supabase Configuration (Required)
# Get these from your Supabase project dashboard: https://supabase.com/dashboard
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Service role key - only needed for admin operations (server-side only)
# NEVER expose this in client-side code
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# -----------------------------------------------------------------------------
# Session Token Secret (Required)
# -----------------------------------------------------------------------------
# Session Token Secret (for HMAC-signing session tokens)
# Generate with: openssl rand -base64 32
# Required for cryptographic security of session management
SESSION_TOKEN_SECRET=your-secret-here

# -----------------------------------------------------------------------------
# App Configuration (Required)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3001

# -----------------------------------------------------------------------------
# OAuth Configuration (Required for Phase 1+)
# Get client_id from Supabase Dashboard after registering Trivia as OAuth client
# See: docs/INITIATIVE_1_REVISED_OAUTH.md - Phase 1
# -----------------------------------------------------------------------------
# OAuth Client ID for Trivia Night (get from Supabase Dashboard → Authentication → OAuth → Clients)
NEXT_PUBLIC_OAUTH_CLIENT_ID=

# OAuth Redirect URI (must match registered redirect URI in Supabase exactly)
# Development: http://localhost:3001/auth/callback
# Production:  https://trivia.beakgaming.com/auth/callback
NEXT_PUBLIC_OAUTH_REDIRECT_URI=http://localhost:3001/auth/callback

# Platform Hub consent page URL (where OAuth authorization redirects)
# Development: http://localhost:3002/oauth/consent
# Production:  https://hub.beakgaming.com/oauth/consent
NEXT_PUBLIC_OAUTH_CONSENT_URL=http://localhost:3002/oauth/consent

# -----------------------------------------------------------------------------
# Cross-App SSO Configuration (Optional - for production)
# -----------------------------------------------------------------------------
# Cookie domain for cross-app SSO. Leave unset for development (localhost).
# Production: Set to .beakgaming.com (note the leading dot) to share cookies across subdomains
# Development: Leave empty - localhost does not support cross-domain cookies
# NEXT_PUBLIC_COOKIE_DOMAIN=

# -----------------------------------------------------------------------------
# Vercel/Turbo Remote Caching (Optional - for CI/CD)
# -----------------------------------------------------------------------------
# TURBO_TOKEN=your-turbo-token
# TURBO_TEAM=your-team-name
