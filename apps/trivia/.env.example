# =============================================================================
# Trivia - Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the values.
# Both apps run as standalone with localStorage-only persistence.
# No auth or database env vars are needed.

# -----------------------------------------------------------------------------
# App Configuration (Required)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3001

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------
# Set to 'false' to disable question sets (default: enabled)
# NEXT_PUBLIC_FEATURE_QUESTION_SETS=true

# -----------------------------------------------------------------------------
# Trivia API Key (Required for API-fetched questions)
# -----------------------------------------------------------------------------
# Get a free key at https://the-trivia-api.com
# THE_TRIVIA_API_KEY=your-api-key

# -----------------------------------------------------------------------------
# Grafana Faro (Frontend Observability - Optional)
# -----------------------------------------------------------------------------
# Faro collector URL for Real User Monitoring (each app has its own Grafana Cloud Frontend app)
# NEXT_PUBLIC_FARO_URL=

# -----------------------------------------------------------------------------
# Vercel/Turbo Remote Caching (Optional - for CI/CD)
# -----------------------------------------------------------------------------
# TURBO_TOKEN=your-turbo-token
# TURBO_TEAM=your-team-name
