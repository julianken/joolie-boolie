{
  "name": "@joolie-boolie/trivia",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port ${PORT:-3001}",
    "build": "next build",
    "postbuild": "if [ -n \"$SENTRY_AUTH_TOKEN\" ]; then sentry-cli sourcemaps inject .next && sentry-cli sourcemaps upload --org $SENTRY_ORG --project $SENTRY_PROJECT .next; else echo 'Skipping source map upload (SENTRY_AUTH_TOKEN not set)'; fi",
    "start": "next start --port ${PORT:-3001}",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest --passWithNoTests",
    "test:run": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage --passWithNoTests",
    "analyze": "ANALYZE=true next build"
  },
  "dependencies": {
    "@joolie-boolie/audio": "workspace:*",
    "@joolie-boolie/error-tracking": "workspace:*",
    "@joolie-boolie/game-stats": "workspace:*",
    "@joolie-boolie/sync": "workspace:*",
    "@joolie-boolie/theme": "workspace:*",
    "@joolie-boolie/types": "workspace:*",
    "@joolie-boolie/ui": "workspace:*",
    "@opentelemetry/api": "^1.9.0",
    "@sentry/nextjs": "^10.39.0",
    "@vercel/analytics": "^1.6.1",
    "@vercel/otel": "^2.1.1",
    "@vercel/speed-insights": "^1.3.1",
    "motion": "^12.34.2",
    "next": "16.1.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "serwist": "^9.5.0",
    "uuid": "^13.0.0",
    "web-vitals": "^5.1.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.10"
  },
  "devDependencies": {
    "@joolie-boolie/testing": "workspace:*",
    "@next/bundle-analyzer": "^16.1.3",
    "@opentelemetry/sdk-trace-base": "^2.5.1",
    "@sentry/cli": "^3.2.0",
    "@serwist/turbopack": "^9.5.4",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^5.1.2",
    "@vitest/coverage-v8": "^4.0.17",
    "esbuild-wasm": "^0.27.2",
    "eslint": "^9",
    "eslint-config-next": "16.1.3",
    "jsdom": "^27.4.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.0.17",
    "vitest-axe": "^0.1.0"
  }
}
