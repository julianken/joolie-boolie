    "@beak-gaming/theme": "workspace:*",
    "@beak-gaming/ui": "workspace:*",
    "@serwist/next": "^9.5.0",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.90.1",
    "next": "16.1.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "serwist": "^9.5.0",
    "uuid": "^13.0.0",
