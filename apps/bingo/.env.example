# =============================================================================
# Beak Bingo - Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the values

# -----------------------------------------------------------------------------
# OAuth Client Configuration (Optional)
# -----------------------------------------------------------------------------
# Bingo app can act as an OAuth client to Platform Hub's authorization server.
#
# To enable OAuth mode:
# 1. Register Bingo as an OAuth client in Platform Hub
# 2. Copy the client ID from Platform Hub
# 3. Set NEXT_PUBLIC_OAUTH_CLIENT_ID to that value
# 4. Verify the consent URL matches your Platform Hub deployment
#
# For local development:
# - Platform Hub runs on port 3002
# - Bingo runs on port 3000
# - Redirect URI should match the callback page in Bingo
# - Authorization URL: {CONSENT_URL base}/oauth/authorize
# - Token URL: {CONSENT_URL base}/oauth/token
#
# If these are not set, Bingo will fall back to direct Supabase authentication.

NEXT_PUBLIC_OAUTH_CLIENT_ID=your-oauth-client-id
NEXT_PUBLIC_OAUTH_REDIRECT_URI=http://localhost:3000/auth/callback
NEXT_PUBLIC_OAUTH_CONSENT_URL=http://localhost:3002/oauth/consent

# -----------------------------------------------------------------------------
# Supabase Configuration (Required)
# Get these from your Supabase project dashboard: https://supabase.com/dashboard
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Service role key - only needed for admin operations (server-side only)
# NEVER expose this in client-side code
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# -----------------------------------------------------------------------------
# Session Token Secret (Required)
# -----------------------------------------------------------------------------
# Session Token Secret (for HMAC-signing session tokens)
# Generate with: openssl rand -base64 32
# Required for cryptographic security of session management
SESSION_TOKEN_SECRET=your-secret-here

# -----------------------------------------------------------------------------
# App Configuration (Required)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# OAuth Configuration (Required for Phase 1+)
# Get client_id from Supabase Dashboard after registering Bingo as OAuth client
# See: docs/INITIATIVE_1_REVISED_OAUTH.md - Phase 1
# -----------------------------------------------------------------------------
# OAuth Client ID for Beak Bingo (get from Supabase Dashboard → Authentication → OAuth → Clients)
NEXT_PUBLIC_OAUTH_CLIENT_ID=

# OAuth Redirect URI (must match registered redirect URI in Supabase exactly)
# Development: http://localhost:3000/auth/callback
# Production:  https://bingo.beakgaming.com/auth/callback
NEXT_PUBLIC_OAUTH_REDIRECT_URI=http://localhost:3000/auth/callback

# Platform Hub consent page URL (where OAuth authorization redirects)
# Development: http://localhost:3002/oauth/consent
# Production:  https://hub.beakgaming.com/oauth/consent
NEXT_PUBLIC_OAUTH_CONSENT_URL=http://localhost:3002/oauth/consent

# -----------------------------------------------------------------------------
# Vercel/Turbo Remote Caching (Optional - for CI/CD)
# -----------------------------------------------------------------------------
# TURBO_TOKEN=your-turbo-token
# TURBO_TEAM=your-team-name
