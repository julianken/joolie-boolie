# =============================================================================
# Bingo - Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the values

# -----------------------------------------------------------------------------
# Supabase Configuration (Required)
# Get these from your Supabase project dashboard: https://supabase.com/dashboard
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Service role key - only needed for admin operations (server-side only)
# NEVER expose this in client-side code
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# -----------------------------------------------------------------------------
# Session Token Secret (Required)
# -----------------------------------------------------------------------------
# Session Token Secret (for HMAC-signing session tokens)
# Generate with: openssl rand -hex 32
# Must be exactly 64 characters (32 bytes in hex)
SESSION_TOKEN_SECRET=your-64-character-hex-string-generate-with-openssl-rand-hex-32

# Supabase JWT Secret (for HS256 JWT verification in middleware)
# Get from: https://supabase.com/dashboard/project/_/settings/api → JWT Settings
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# -----------------------------------------------------------------------------
# App Configuration (Required)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# OAuth Configuration (Required for Phase 1+)
# Get client_id from Supabase Dashboard after registering Bingo as OAuth client
# See: docs/INITIATIVE_1_REVISED_OAUTH.md - Phase 1
# -----------------------------------------------------------------------------
# OAuth Client ID for Bingo (get from Platform Hub OAuth client registration)
NEXT_PUBLIC_OAUTH_CLIENT_ID=

# Platform Hub URL (where OAuth authorization and consent page live)
# Development: http://localhost:3002
# Production:  https://joolie-boolie.com
NEXT_PUBLIC_PLATFORM_HUB_URL=http://localhost:3002

# OAuth Redirect URI (must match registered redirect URI exactly)
# Development: http://localhost:3000/auth/callback
# Production:  https://bingo.joolie-boolie.com/auth/callback
NEXT_PUBLIC_OAUTH_REDIRECT_URI=http://localhost:3000/auth/callback

# Platform Hub consent page URL (where OAuth authorization redirects)
# Development: http://localhost:3002/oauth/consent
# Production:  https://joolie-boolie.com/oauth/consent
NEXT_PUBLIC_OAUTH_CONSENT_URL=http://localhost:3002/oauth/consent

# -----------------------------------------------------------------------------
# Cross-App SSO Configuration (Optional - for production)
# -----------------------------------------------------------------------------
# Cookie domain for cross-app SSO. Leave unset for development (localhost).
# Production: Set to .joolie-boolie.com (note the leading dot) to share cookies across subdomains
# Development: Leave empty - localhost does not support cross-domain cookies
# COOKIE_DOMAIN=

# -----------------------------------------------------------------------------
# E2E Testing Configuration (Optional)
# -----------------------------------------------------------------------------
# SECURITY: NEVER set this to "true" in production .env files
#
# Enable E2E test mode to bypass rate limiting during Playwright test runs.
# When E2E_TESTING=true, Platform Hub middleware skips rate limit checks
# (10 req/min limit), allowing 6 parallel test workers to authenticate
# without hitting limits.
#
# Other security measures (CORS, body size limits, session management) remain
# active even when rate limiting is bypassed.
#
# Rate limiting is fully enforced in dev/production when E2E_TESTING is unset
# or set to any value other than "true".
#
# Set to "true" ONLY when running E2E tests: pnpm test:e2e
# E2E_TESTING=
#
# E2E JWT signing secret (required when E2E_TESTING=true)
# Used to verify test JWTs in middleware. Must match the value used by Platform Hub.
# E2E_JWT_SECRET=e2e-test-secret-key-that-is-at-least-32-characters-long

# -----------------------------------------------------------------------------
# Grafana Faro (Frontend Observability - Optional)
# -----------------------------------------------------------------------------
# Faro collector URL for Real User Monitoring (each app has its own Grafana Cloud Frontend app)
# NEXT_PUBLIC_FARO_URL=

# -----------------------------------------------------------------------------
# Vercel/Turbo Remote Caching (Optional - for CI/CD)
# -----------------------------------------------------------------------------
# TURBO_TOKEN=your-turbo-token
# TURBO_TEAM=your-team-name
