# =============================================================================
# Beak Gaming Platform Hub - Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the values

# -----------------------------------------------------------------------------
# Supabase Configuration (Required)
# Get these from your Supabase project dashboard: https://supabase.com/dashboard
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Service role key - only needed for admin operations (server-side only)
# NEVER expose this in client-side code
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# -----------------------------------------------------------------------------
# Email Configuration (Configured in Supabase Dashboard)
# -----------------------------------------------------------------------------
# SMTP settings are configured directly in Supabase dashboard, not via .env files.
# This project uses Resend (https://resend.com) for email delivery to bypass
# Supabase's built-in rate limits (2 emails/hour on free tier).
#
# Resend Free Tier: 3,000 emails/month, 100 emails/day
#
# To configure SMTP in Supabase:
# 1. Go to: https://supabase.com/dashboard/project/{your-project-id}/auth/smtp
# 2. Enable custom SMTP
# 3. Fill in Resend credentials:
#    - Host: smtp.resend.com
#    - Port: 587
#    - Username: resend
#    - Password: {your-resend-api-key}
# 4. Set sender: onboarding@resend.dev (for testing) or your verified domain
#
# For production: Verify your domain in Resend dashboard to use custom sender address
# For development: Use onboarding@resend.dev (no verification required)

# -----------------------------------------------------------------------------
# Security Configuration (Required)
# -----------------------------------------------------------------------------
# Session token secret for HMAC-signed JWT tokens
# CRITICAL: Generate with: openssl rand -hex 32
# Must be exactly 64 characters (32 bytes in hex)
SESSION_TOKEN_SECRET=your-64-character-hex-string-generate-with-openssl-rand-hex-32

# -----------------------------------------------------------------------------
# App Configuration (Required)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3002

# URLs to other apps (for cross-app navigation)
NEXT_PUBLIC_BINGO_URL=http://localhost:3000
NEXT_PUBLIC_TRIVIA_URL=http://localhost:3001

# -----------------------------------------------------------------------------
# CORS Configuration (Required for OAuth endpoints)
# -----------------------------------------------------------------------------
# Comma-separated list of allowed origins for OAuth cross-origin requests
# Example: http://localhost:3000,http://localhost:3001,https://bingo.example.com
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002

# -----------------------------------------------------------------------------
# Cross-App SSO Configuration (Optional - for production)
# -----------------------------------------------------------------------------
# Cookie domain for cross-app SSO. Leave unset for development (localhost).
# Production: Set to .beakgaming.com (note the leading dot) to share cookies across subdomains
# Development: Leave empty - localhost does not support cross-domain cookies
# COOKIE_DOMAIN=

# -----------------------------------------------------------------------------
# Redis Configuration (Optional - for production rate limiting)
# -----------------------------------------------------------------------------
# REDIS_URL - Upstash Redis REST URL for rate limiting across multiple instances
# Get from: https://console.upstash.com/
# Format: https://your-redis-instance.upstash.io
# If not set, rate limiting falls back to in-memory (single instance only)
# REDIS_URL=https://your-redis-instance.upstash.io
# REDIS_TOKEN=your-redis-token

# -----------------------------------------------------------------------------
# Security Configuration (Optional)
# -----------------------------------------------------------------------------
# Maximum request body size in MB (default: 1)
# Prevents DoS attacks via large payload submissions
MAX_BODY_SIZE_MB=1

# -----------------------------------------------------------------------------
# E2E Testing Configuration (Optional)
# -----------------------------------------------------------------------------
# SECURITY: NEVER set this to "true" in production .env files
#
# Enable E2E test mode to bypass rate limiting during Playwright test runs.
# When E2E_TESTING=true, Platform Hub middleware skips rate limit checks
# (10 req/min limit), allowing 6 parallel test workers to authenticate
# without hitting limits.
#
# Other security measures (CORS, body size limits, session management) remain
# active even when rate limiting is bypassed.
#
# Rate limiting is fully enforced in dev/production when E2E_TESTING is unset
# or set to any value other than "true".
#
# Set to "true" ONLY when running E2E tests: pnpm test:e2e
#
# Implementation: apps/platform-hub/src/middleware.ts (lines 62, 100, 117)
# E2E_TESTING=
#
# E2E JWT signing secret (required when E2E_TESTING=true)
# Used to sign test JWTs in login/token routes and verify in middleware.
# Must be the same value in all app .env.local files.
# E2E_JWT_SECRET=e2e-test-secret-key-that-is-at-least-32-characters-long

# -----------------------------------------------------------------------------
# Grafana Faro (Frontend Observability - Optional)
# -----------------------------------------------------------------------------
# Faro collector URL for Real User Monitoring (each app has its own Grafana Cloud Frontend app)
# NEXT_PUBLIC_FARO_URL=

# -----------------------------------------------------------------------------
# Vercel/Turbo Remote Caching (Optional - for CI/CD)
# -----------------------------------------------------------------------------
# TURBO_TOKEN=your-turbo-token
# TURBO_TEAM=your-team-name
