# =============================================================================
# Beak Gaming Platform Hub - Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the values

# -----------------------------------------------------------------------------
# Supabase Configuration (Required)
# Get these from your Supabase project dashboard: https://supabase.com/dashboard
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Service role key - only needed for admin operations (server-side only)
# NEVER expose this in client-side code
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# -----------------------------------------------------------------------------
# Security Configuration (Required)
# -----------------------------------------------------------------------------
# Session token secret for HMAC-signed JWT tokens
# CRITICAL: Generate with: openssl rand -hex 32
# Must be exactly 64 characters (32 bytes in hex)
SESSION_TOKEN_SECRET=your-64-character-hex-string-generate-with-openssl-rand-hex-32

# -----------------------------------------------------------------------------
# App Configuration (Required)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3002

# URLs to other apps (for cross-app navigation)
NEXT_PUBLIC_BINGO_URL=http://localhost:3000
NEXT_PUBLIC_TRIVIA_URL=http://localhost:3001

# -----------------------------------------------------------------------------
# CORS Configuration (Required for OAuth endpoints)
# -----------------------------------------------------------------------------
# Comma-separated list of allowed origins for OAuth cross-origin requests
# Example: http://localhost:3000,http://localhost:3001,https://bingo.example.com
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002

# -----------------------------------------------------------------------------
# Cross-App SSO Configuration (Optional - for production)
# -----------------------------------------------------------------------------
# Cookie domain for cross-app SSO. Leave unset for development (localhost).
# Production: Set to .beakgaming.com (note the leading dot) to share cookies across subdomains
# Development: Leave empty - localhost does not support cross-domain cookies
# NEXT_PUBLIC_COOKIE_DOMAIN=

# -----------------------------------------------------------------------------
# Redis Configuration (Optional - for production rate limiting)
# -----------------------------------------------------------------------------
# REDIS_URL - Upstash Redis REST URL for rate limiting across multiple instances
# Get from: https://console.upstash.com/
# Format: https://your-redis-instance.upstash.io
# If not set, rate limiting falls back to in-memory (single instance only)
# REDIS_URL=https://your-redis-instance.upstash.io
# REDIS_TOKEN=your-redis-token

# -----------------------------------------------------------------------------
# Security Configuration (Optional)
# -----------------------------------------------------------------------------
# Maximum request body size in MB (default: 1)
# Prevents DoS attacks via large payload submissions
MAX_BODY_SIZE_MB=1

# -----------------------------------------------------------------------------
# Vercel/Turbo Remote Caching (Optional - for CI/CD)
# -----------------------------------------------------------------------------
# TURBO_TOKEN=your-turbo-token
# TURBO_TEAM=your-team-name
