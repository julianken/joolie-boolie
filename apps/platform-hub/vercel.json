{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "framework": "nextjs",
  "installCommand": "pnpm install --frozen-lockfile",
  "buildCommand": "cd ../.. && pnpm turbo build --filter=@joolie-boolie/platform-hub...",
  "outputDirectory": ".next",
  "env": {
    "TURBO_TEAM": "joolie-boolie",
    "TURBO_REMOTE_ONLY": "true"
  },
  "crons": [
    {
      "path": "/api/cron/cleanup-authorizations",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/cron/cleanup-sessions",
      "schedule": "0 */6 * * *"
    }
  ],
  "redirects": [
    {
      "source": "/bingo",
      "destination": "https://bingo.joolie-boolie.com",
      "permanent": false
    },
    {
      "source": "/trivia",
      "destination": "https://trivia.joolie-boolie.com",
      "permanent": false
    }
  ]
}
