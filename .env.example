# =============================================================================
# Beak Gaming Platform - Root Environment Variables
# =============================================================================
# These are shared configuration values used across all apps.
# Each app also has its own .env.example with app-specific variables.

# -----------------------------------------------------------------------------
# Turbo Remote Caching (Optional)
# Speeds up builds by caching artifacts remotely
# Get token from: https://vercel.com/account/tokens
# -----------------------------------------------------------------------------
TURBO_TOKEN=your-turbo-token
TURBO_TEAM=your-team-name
TURBO_REMOTE_ONLY=true

# -----------------------------------------------------------------------------
# Supabase Configuration
# All apps share the same Supabase project
# Get these from: https://supabase.com/dashboard/project/_/settings/api
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
